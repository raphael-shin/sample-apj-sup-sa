# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Transport ──────────────────────────────────────────────────────────────────
DAILY_API_KEY=            # Get from https://pipecat.daily.co/your-org/settings/keys
# DAILY_ROOM_URL=         # Optional: leave empty to create a new room per session

# ── AWS credentials ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
# AWS_SESSION_TOKEN=      # Required if your credentials use a session token

# ── AgentCore ──────────────────────────────────────────────────────────────────
AWS_AGENT_ARN=

# ── Cognito (headless ROPC auth for the demo user) ─────────────────────────────
COGNITO_CLIENT_ID=
COGNITO_USER_POOL_ID=
DEMO_USERNAME=            # e.g. orion.moonshadow@example-mythicalunicorns.com
DEMO_PASSWORD=            # Cognito demo user password

# ── Deepgram ───────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_VOICE_ID=aura-2-helena-en

# Deepgram Flux — better turn-taking detection (recommended for production)
USE_FLUX=false

# SageMaker — run Deepgram models on your own endpoints instead of direct API
USE_SAGEMAKER=false
SAGEMAKER_STT_ENDPOINT_NAME=
SAGEMAKER_TTS_ENDPOINT_NAME=
