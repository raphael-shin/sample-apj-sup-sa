# AWS Configuration
AWS_REGION=us-west-2
AWS_PROFILE=default

# Classifier model (cheap & fast — used to score query complexity)
# CLASSIFIER_MODEL_ID=amazon.nova-micro-v1:0

# Baseline model for A/B comparison (always-use-this-model mode)
# DEFAULT_BASELINE_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Comma-separated model families to enable (empty = all)
# ENABLED_FAMILIES=claude,nova,llama,deepseek,gemma,qwen,kimi,glm

# Request / response log (JSONL)
# LOG_FILE=logs/routing.jsonl
