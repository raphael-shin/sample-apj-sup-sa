# ============================================================================
# Streamlit UI-specific environment variables
# ----------------------------------------------------------------------------
# VPC / DB / host values are loaded automatically from ../../infra/.env.
# Put only the values here that are finalized after `cdk deploy`.
# ============================================================================

# Copy from the CloudFormation Outputs after `cdk deploy`
ORCHESTRATOR_ARN=arn:aws:bedrock-agentcore:us-east-1:XXXXXXXXXXXX:runtime/aurora_upgrade_orchestrator-XXXX
VARIABLES_COMPARE_ARN=arn:aws:bedrock-agentcore:us-east-1:XXXXXXXXXXXX:runtime/aurora_variables_compare-XXXX
ERROR_LOG_ANALYZER_ARN=arn:aws:bedrock-agentcore:us-east-1:XXXXXXXXXXXX:runtime/aurora_error_log_analyzer-XXXX
UPGRADE_READINESS_ARN=arn:aws:bedrock-agentcore:us-east-1:XXXXXXXXXXXX:runtime/aurora_upgrade_readiness_analyzer-XXXX
QUERY_RISK_SCORER_ARN=arn:aws:bedrock-agentcore:us-east-1:XXXXXXXXXXXX:runtime/aurora_query_risk_scorer-XXXX
PLAN_DIFF_ARN=arn:aws:bedrock-agentcore:us-east-1:XXXXXXXXXXXX:runtime/aurora_plan_diff-XXXX
