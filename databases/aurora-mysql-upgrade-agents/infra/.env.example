# ============================================================================
# Aurora MySQL Blue-Green Upgrade — CDK Deployment Environment
# ============================================================================
# 1) cp .env.example .env
# 2) Fill in the values below for your environment.
# 3) cdk deploy
# ============================================================================

# ----------------------------------------------------------------------------
# AWS account / region (required)
# ----------------------------------------------------------------------------
CDK_DEFAULT_ACCOUNT=XXXXXXXXXXXX
CDK_DEFAULT_REGION=us-east-1

# ----------------------------------------------------------------------------
# Container builder (optional)
# Uncomment the line below if you use Finch instead of Docker Desktop.
# The Finch VM must be started separately with `finch vm start`.
# ----------------------------------------------------------------------------
# CDK_DOCKER=finch

# ----------------------------------------------------------------------------
# Existing VPC / Subnet / Security Group (required)
# The VPC, subnets, and DB are assumed to already exist.
# The AgentCore Runtime accesses RDS from inside this VPC.
# ----------------------------------------------------------------------------
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
# Comma-separated private subnet IDs (at least 2 recommended)
SUBNET_IDS=subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy
# Comma-separated security group IDs (must allow outbound 3306 to RDS)
SECURITY_GROUP_IDS=sg-xxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# S3 report bucket name prefix (required)
# The actual bucket name is generated as `<this value>-<DEPLOYMENT_SUFFIX>`.
# (e.g. prefix=aurora-mysql-upgrade-reports -> actual: aurora-mysql-upgrade-reports-d2be5a)
# Only lowercase letters, digits, and hyphens (-) are allowed.
# ----------------------------------------------------------------------------
REPORTS_BUCKET_NAME=aurora-mysql-upgrade-reports

# ----------------------------------------------------------------------------
# Report language (optional — default ko)
# Output language for the markdown reports and summary generated by all agents.
#   ko = Korean, en = English
# The Streamlit UI reads this value and passes it in the orchestrator payload.
# ----------------------------------------------------------------------------
REPORT_LANGUAGE=ko

# ----------------------------------------------------------------------------
# Bedrock model ID (optional — default us.anthropic.claude-sonnet-4-6)
# Injected into every agent runtime as the BEDROCK_MODEL_ID env var, so you can
# change the model without editing agent code (just redeploy).
# us-east-1 has no in-region endpoint for this model — use a geo inference
# profile prefix (us. / eu. / etc.). Examples:
#   us.anthropic.claude-sonnet-4-6                 (Sonnet 4.6, default)
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0   (Sonnet 4.5)
# ----------------------------------------------------------------------------
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ----------------------------------------------------------------------------
# Database connection (required)
# Use the Aurora cluster endpoint (it routes to the writer automatically).
# Use the cluster endpoint (`*.cluster-XXXXX.<region>.rds.amazonaws.com`),
# not the instance endpoint (`*.<az>.rds.amazonaws.com`).
# With a Blue-Green Deployment, Blue and Green share the same credentials
# (Green is a full clone of Blue, so the mysql.user table matches too), so a
# single secret authenticates both.
# ----------------------------------------------------------------------------
BLUE_HOST=your-blue-cluster.cluster-XXXXXX.us-east-1.rds.amazonaws.com
GREEN_HOST=your-green-cluster.cluster-XXXXXX.us-east-1.rds.amazonaws.com

# DB credentials are read from AWS Secrets Manager at run time — the password
# is NEVER stored here or sent in any payload. Give the secret name or ARN.
# The secret must be JSON with at least {"username": "...", "password": "..."}
# (the format RDS-managed master secrets use). The deploy grants the agents'
# runtime role secretsmanager:GetSecretValue on exactly this secret.
DB_SECRET_ID=your-db-secret-name-or-arn
# Optional: override the secret's "username" (leave blank to use the secret's).
DB_USER=

# ----------------------------------------------------------------------------
# CloudWatch Logs (used by the Error Log Analyzer agent)
# Aurora MySQL creates one log group per cluster.
# Prerequisite: "Error log" must be enabled under the Green cluster's
# "Log exports" (RDS console -> cluster -> Modify -> Log exports -> Error log).
# If it is not enabled, the log group will not exist at all.
#
# Format: /aws/rds/cluster/<GREEN_CLUSTER_ID>/error
# A Green cluster ID created by Blue/Green Deployment is usually `<blue>-green-xxxxxx`.
# ----------------------------------------------------------------------------
GREEN_LOG_GROUP=/aws/rds/cluster/your-green-cluster-id/error

# ----------------------------------------------------------------------------
# Deployment identifier suffix (auto-generated — leave blank)
# On the first `cdk deploy`, a 6-character hex value is generated and written
# to this .env. It is appended to agent names to avoid collisions within the
# same account/region. Keep the same value when redeploying the same stack,
# so do not delete it manually.
# ----------------------------------------------------------------------------
# DEPLOYMENT_SUFFIX=

# ----------------------------------------------------------------------------
# Agent names (optional — defaults recommended)
# Defaults are built as `<role>_<DEPLOYMENT_SUFFIX>`.
# If you set a value explicitly, it is used as-is (no suffix is appended).
# ----------------------------------------------------------------------------
# ORCHESTRATOR_NAME=
# VARIABLES_COMPARE_NAME=
# ERROR_LOG_ANALYZER_NAME=
# UPGRADE_READINESS_NAME=
# QUERY_RISK_SCORER_NAME=
# PLAN_DIFF_NAME=
